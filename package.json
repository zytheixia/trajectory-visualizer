{
  "name": "trajectory-visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A dependency-free visualization tool for agent execution traces.",
  "exports": {
    ".": "./src/index.js",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src/index.js",
    "src/index.d.ts",
    "src/adapters",
    "src/config/traceConfig.js",
    "src/core",
    "src/layouts",
    "src/viewer",
    "src/styles.css",
    "README.md",
    "package.json"
  ],
  "bin": {
    "visualize": "./bin/visualize.js"
  },
  "scripts": {
    "check": "find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "dev": "node ./scripts/server.js",
    "open": "node ./bin/visualize.js",
    "start": "node ./scripts/server.js"
  },
  "types": "./src/index.d.ts"
}
