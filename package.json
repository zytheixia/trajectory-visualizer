{
  "name": "trajectory-visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A dependency-free visualization tool for agent execution traces.",
  "exports": {
    ".": "./src/index.js",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src/index.js",
    "src/adapters",
    "src/config/traceConfig.js",
    "src/core",
    "src/layouts",
    "src/viewer",
    "src/styles.css",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "check": "find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "dev": "python3 -m http.server 5173",
    "start": "python3 -m http.server 5173"
  }
}
